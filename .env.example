# Copy to .env and fill in. .env is gitignored — never commit real values.

# ── Postgres (docker-compose reads these; the app builds DATABASE_URL from them)
POSTGRES_USER=askharder
POSTGRES_PASSWORD=change-me
POSTGRES_DB=askharder
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://askharder:change-me@localhost:5432/askharder

# ── App
APP_ENV=dev

# ── LLM backend
# mock     — deterministic fake LLM, no API keys, full flow works (default)
# deepseek — real DeepSeek intake/plan/interviewer + Anthropic judge
LLM_BACKEND=mock

# ── DeepSeek (required when LLM_BACKEND=deepseek)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model per role — any DeepSeek model id (e.g. deepseek-v4-pro, deepseek-v4-flash)
# DEEPSEEK_INTAKE_MODEL=deepseek-v4-pro
# DEEPSEEK_PLAN_MODEL=deepseek-v4-pro
# DEEPSEEK_INTERVIEWER_MODEL=deepseek-v4-pro

# v4 thinking mode — one global switch for all three DeepSeek roles
# enabled  — chain-of-thought before the answer (slower; reasoning not shown in UI)
# disabled — skip reasoning trace (faster, cheaper)
# DEEPSEEK_THINKING=enabled
# DEEPSEEK_REASONING_EFFORT=high   # high | max (only when DEEPSEEK_THINKING=enabled)

# DEEPSEEK_INTAKE_MAX_TOKENS=1024
# DEEPSEEK_PLAN_MAX_TOKENS=4096
# DEEPSEEK_INTERVIEWER_MAX_TOKENS=512

# ── Anthropic judge (required when LLM_BACKEND=deepseek)
# ANTHROPIC_API_KEY=
# ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6
# ANTHROPIC_JUDGE_MAX_TOKENS=4096
