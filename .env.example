# Copy to .env and fill in. .env is gitignored — never commit real values.

# Postgres (docker-compose reads these; the app builds DATABASE_URL from them)
POSTGRES_USER=askharder
POSTGRES_PASSWORD=change-me
POSTGRES_DB=askharder
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://askharder:change-me@localhost:5432/askharder

# App
APP_ENV=dev

# LLM — mock (no API keys) or deepseek (real intake + plan + interviewer + Anthropic judge)
LLM_BACKEND=mock
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_INTAKE_MODEL=deepseek-chat
# DEEPSEEK_PLAN_MODEL=deepseek-chat
# DEEPSEEK_INTERVIEWER_MODEL=deepseek-chat
# DEEPSEEK_INTERVIEWER_MAX_TOKENS=512
# ANTHROPIC_API_KEY=
# ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6
# ANTHROPIC_JUDGE_MAX_TOKENS=4096
